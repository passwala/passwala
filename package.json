{
  "name": "passwalaa",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --config vite.config.web.js --mode web --port 3000 --host --force",
    "dev:webapp": "vite --config vite.config.webapp.js --mode webapp --port 3001 --host --force",
    "dev:vendor": "vite --config vite.config.vendor.js --mode vendor --port 3002 --host --force",
    "dev:rider": "vite --config vite.config.rider.js --mode rider --port 3003 --host --force",
    "dev:admin": "vite --config vite.config.admin.js --mode admin --port 3005 --host --force",
    "dev:all": "concurrently \"npm run dev:all:apps\" \"npm run server\"",
    "dev:all:apps": "concurrently \"npm run dev:web\" \"npm run dev:webapp\" \"npm run dev:vendor\" \"npm run dev:rider\" \"npm run dev:admin\"",
    "dev:headless": "set HEADLESS=true && concurrently \"npm run dev:web\" \"npm run dev:webapp\" \"npm run dev:vendor\" \"npm run dev:rider\" \"npm run dev:admin\" \"npm run server\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:api": "node server/index.js --headless"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.4",
    "@supabase/supabase-js": "^2.100.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.477.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
}
